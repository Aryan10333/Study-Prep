  "cells": [
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "# 05 Classical NLP Models & Baseline Classifiers\n",
        "\n",
        "**Real-World Scenario**: Enterprise Support Ticket Automated Category Routing System.\n",
        "\n",
        "This notebook demonstrates building a Scikit-Learn `Pipeline` combining `TfidfVectorizer` + `LogisticRegression`, computing Naive Bayes sentiment probabilities, saving model artifacts into a hidden `.model_cache/` directory, and executing a **Complete GenAI Automated Routing LLM Call**."
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "## Step 1: Environment Setup & Local Cache Configuration"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "import os\n",
        "from dotenv import load_dotenv\n",
        "\n",
        "# Load API keys from root .env file\n",
        "load_dotenv()\n",
        "\n",
        "# Create hidden model cache directory for local pipeline artifact persistence\n",
        "os.makedirs(\".model_cache\", exist_ok=True)\n",
        "\n",
        "print(\"=== Environment Setup ===\")\n",
        "print(\"OPENAI_API_KEY present:\", bool(os.getenv(\"OPENAI_API_KEY\")))\n",
        "print(\"GEMINI_API_KEY present:\", bool(os.getenv(\"GEMINI_API_KEY\")))\n",
        "print(\"Hidden Cache Directory Path:\", os.path.abspath(\".model_cache\"))"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "## Step 2: Real-World Enterprise Support Ticket Corpus Setup"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "X_train = [\n",
        "    \"Database connection timeout on port 5432 postgresql primary replica\",\n",
        "    \"SQL query execution failed due to lock contention on table user_sessions\",\n",
        "    \"Billing credit card payment authorization declined HTTP 402 error\",\n",
        "    \"Invoice subscription renewal charges failed for quarterly billing cycle\",\n",
        "    \"Kubernetes pod container worker node crash out of memory OOM killer\",\n",
        "    \"Monthly billing invoice statement shows unexpected overage charge\"\n",
        "]\n",
        "y_train = [\"Infrastructure\", \"Infrastructure\", \"Billing\", \"Billing\", \"Infrastructure\", \"Billing\"]\n",
        "\n",
        "print(f\"Loaded {len(X_train)} labeled support ticket training samples.\")\n",
        "print(\"Sample #1:\", X_train[0], \"-> Category:\", y_train[0])"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "## Step 3: Training Baseline Pipeline & Model Persistence in `.model_cache/`"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "import joblib\n",
        "from sklearn.feature_extraction.text import TfidfVectorizer\n",
        "from sklearn.linear_model import LogisticRegression\n",
        "from sklearn.pipeline import Pipeline\n",
        "\n",
        "# Build Scikit-Learn Pipeline\n",
        "pipeline = Pipeline([\n",
        "    (\"tfidf\", TfidfVectorizer(lowercase=True, ngram_range=(1, 2), sublinear_tf=True)),\n",
        "    (\"clf\", LogisticRegression(C=1.0, max_iter=100))\n",
        "])\n",
        "\n",
        "# Fit Pipeline\n",
        "pipeline.fit(X_train, y_train)\n",
        "\n",
        "# Save Pipeline artifact to hidden folder\n",
        "model_path = os.path.join(\".model_cache\", \"ticket_pipeline.pkl\")\n",
        "joblib.dump(pipeline, model_path)\n",
        "print(f\"=== Scikit-Learn Pipeline Artifact Saved to Hidden Folder: {model_path} ===\")"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "## Step 4: Pipeline Model Inference & Confidence Scoring"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "X_test = [\n",
        "    \"PostgreSQL database primary server timeout failure\",\n",
        "    \"Credit card billing failed to process quarterly invoice\"\n",
        "]\n",
        "\n",
        "preds = pipeline.predict(X_test)\n",
        "probas = pipeline.predict_proba(X_test)\n",
        "\n",
        "print(\"=== Classical Logistic Regression Inference Results ===\")\n",
        "for text, pred, proba in zip(X_test, preds, probas):\n",
        "    confidence = max(proba)\n",
        "    print(f\"Ticket: '{text}'\")\n",
        "    print(f"  -> Predicted Category: {pred} (Confidence: {confidence*100:.1f}%)\n")"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "## Step 5: Executing Complete GenAI Category Routing LLM Call"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "from langchain_openai import ChatOpenAI\n",
        "from langchain_core.prompts import ChatPromptTemplate\n",
        "\n",
        "test_ticket = X_test[0]\n",
        "classical_pred = preds[0]\n",
        "\n",
        "if os.getenv(\"OPENAI_API_KEY\"):\n",
        "    prompt = ChatPromptTemplate.from_template('''You are an Automated Customer Support Operations AI.\n",
        "A classical baseline classifier routed ticket: '{ticket}' to Category: '{category}'.\n",
        "Confirm or refine this category and output 2 immediate resolution steps for the assigned team.\n",
        "\n",
        "Resolution Action Plan:''')\n",
        "    \n",
        "    llm = ChatOpenAI(model=\"gpt-4o-mini\", temperature=0.0)\n",
        "    \n",
        "    response = llm.invoke(prompt.format(ticket=test_ticket, category=classical_pred))\n",
        "    print(\"=== Complete GenAI Ticket Routing Action Plan Response ===\")\n",
        "    print(response.content)\n",
        "else:\n",
        "    print(\"[NOTICE] OPENAI_API_KEY not found in .env. Skipping live LLM call.\")"
      ]
    }
  ],
