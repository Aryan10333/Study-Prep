{
  "cells": [
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "# 04 Word Embeddings: Word2Vec, GloVe, FastText & Vector Arithmetic\n",
        "\n",
        "**Real-World Scenario**: Enterprise Cloud Architecture & Microservice Vector Search System.\n",
        "\n",
        "This notebook demonstrates training a custom Gensim Skip-Gram Word2Vec embedding model, executing vector similarity arithmetic, saving embedding artifacts into a hidden `.model_cache/` directory, and executing a **Complete GenAI Recommendation LLM Call**."
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "## Step 1: Environment Setup & Local Cache Configuration"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "import os\n",
        "from dotenv import load_dotenv\n",
        "\n",
        "# Load API keys from root .env file\n",
        "load_dotenv()\n",
        "\n",
        "# Create hidden model cache directory for local pipeline artifact persistence\n",
        "os.makedirs(\".model_cache\", exist_ok=True)\n",
        "\n",
        "print(\"=== Environment Setup ===\")\n",
        "print(\"OPENAI_API_KEY present:\", bool(os.getenv(\"OPENAI_API_KEY\")))\n",
        "print(\"GEMINI_API_KEY present:\", bool(os.getenv(\"GEMINI_API_KEY\")))\n",
        "print(\"Hidden Cache Directory Path:\", os.path.abspath(\".model_cache\"))"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "## Step 2: Real-World Enterprise Cloud Technical Corpus Setup"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "corpus = [\n",
        "    [\"microservice\", \"communicates\", \"with\", \"database\", \"via\", \"grpc\", \"protocol\"],\n",
        "    [\"database\", \"failover\", \"replica\", \"executed\", \"automatically\", \"on\", \"timeout\"],\n",
        "    [\"grpc\", \"protocol\", "ensures", \"low\", \"latency\", \"microservice\", \"rpc\", \"communication\"],\n",
        "    [\"kubernetes\", \"cluster\", \"deploys\", \"microservice\", \"container\", \"pods\"],\n",
        "    [\"redis\", \"cache\", \"stores\", \"frequent\", \"database\", \"query\", \"results\"]\n",
        "]\n",
        "\n",
        "print(f\"Loaded {len(corpus)} technical corpus sentences.\")\n",
        "print(\"Sample Tokenized Sentence:\", corpus[0])"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "## Step 3: Training Gensim Skip-Gram Word2Vec & Model Persistence in `.model_cache/`"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "from gensim.models import Word2Vec\n",
        "\n",
        "# Train Gensim Skip-Gram Word2Vec Model\n",
        "w2v_model = Word2Vec(\n",
        "    sentences=corpus,\n",
        "    vector_size=30,\n",
        "    window=3,\n",
        "    min_count=1,\n",
        "    sg=1,         # Skip-Gram\n",
        "    negative=5,\n",
        "    epochs=200\n",
        ")\n",
        "\n",
        "# Save Word2Vec model artifact to hidden folder\n",
        "model_save_path = os.path.join(\".model_cache\", \"word2vec_technical.model\")\n",
        "w2v_model.save(model_save_path)\n",
        "print(f\"=== Gensim Word2Vec Model Saved to Hidden Folder: {model_save_path} ===\")"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "## Step 4: Embedding Similarity & Vector Space Arithmetic"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "sim_score = w2v_model.wv.similarity(\"microservice\", \"database\")\n",
        "most_similar = w2v_model.wv.most_similar(\"microservice\", topn=3)\n",
        "\n",
        "print(\"=== Embedding Vector Similarity Benchmarks ===\")\n",
        "print(f\"Similarity ('microservice', 'database'): {sim_score:.4f}\")\n",
        "print(\"\nTop 3 Most Similar Words to 'microservice':\")\n",
        "for w, score in most_similar:\n",
        "    print(f\"  - Word: {w:<15} | Cosine Similarity: {score:.4f}\")"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "## Step 5: Executing Complete GenAI Architecture Recommendation LLM Call"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "from langchain_openai import ChatOpenAI\n",
        "from langchain_core.prompts import ChatPromptTemplate\n",
        "\n",
        "top_related = [w for w, _ in most_similar]\n",
        "\n",
        "if os.getenv(\"OPENAI_API_KEY\"):\n",
        "    prompt = ChatPromptTemplate.from_template('''You are an Enterprise Cloud Architect AI.\n",
        "Using the vector space nearest neighbors: {neighbors} for target component 'microservice',\n",
        "recommend an infrastructure architecture pattern.\n",
        "\n",
        "Architecture Recommendation:''')\n",
        "    \n",
        "    llm = ChatOpenAI(model=\"gpt-4o-mini\", temperature=0.0)\n",
        "    \n",
        "    response = llm.invoke(prompt.format(neighbors=\", \".join(top_related)))\n",
        "    print(\"=== Complete GenAI Cloud Recommendation LLM Response ===\")\n",
        "    print(response.content)\n",
        "else:\n",
        "    print(\"[NOTICE] OPENAI_API_KEY not found in .env. Skipping live LLM call.\")"
      ]
    }
  ],
